APP_ENV=local
APP_NAME=finbot
APP_DEBUG=true
APP_VERSION=0.2.0

DATABASE_URL=sqlite:///./data/finbot.sqlite3
DATABASE_AUTO_MIGRATE=true

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_BASE_URL=https://api.openai.com/v1
AI_PROVIDER=openai
AI_ENABLED=false

GOOGLE_SHEETS_ENABLED=false
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=

# Financial workflow and optional Supabase Storage backups.
TRANSACTION_CONFIRMATION_THRESHOLD=0.75
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BACKUP_BUCKET=finbot-backups

LOG_LEVEL=INFO

# Web API and Lovable
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:8080,https://seu-projeto.lovable.app
CORS_ALLOWED_ORIGIN_REGEX=https://.*\.(lovable\.app|lovableproject\.com)
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Authorization,Content-Type,X-Request-ID
CORS_ALLOW_CREDENTIALS=true
PUBLIC_API_URL=http://127.0.0.1:8000

# Web authentication. Generate a long random value for JWT_SECRET.
JWT_SECRET=change-me-in-production
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=30
AUTH_ALLOW_REGISTRATION=false
ADMIN_EMAIL=
ADMIN_PASSWORD=

# External HTTP and telemetry
HTTP_CONNECT_TIMEOUT_SECONDS=3
HTTP_READ_TIMEOUT_SECONDS=8
METRICS_RETENTION_DAYS=90

# Groq (opcional; somente backend)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT_SECONDS=8
GROQ_MAX_PROMPT_CHARS=4000
GROQ_MAX_OUTPUT_TOKENS=300
GROQ_REQUESTS_PER_MINUTE=10
